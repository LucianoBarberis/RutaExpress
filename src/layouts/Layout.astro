---
import Analytics from '@vercel/analytics/astro';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: URL;
}

const {
  title = 'Ruta Express — Transporte para tu pueblo',
  description = 'Información unificada de colectivos y comisionistas. Horarios, rutas y contactos de transporte de Chañar Ladeado a Rosario.',
  image = '/og-image.png',
  canonical,
} = Astro.props;

const url = canonical ?? Astro.url;
const siteUrl = Astro.site ?? new URL('https://rutaexpress.com.ar');
const fullUrl = new URL(url.pathname, siteUrl);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="google-adsense-account" content="ca-pub-4201246651894763">

    <link rel="icon" href="/favicon.ico?v=2" />
    <link rel="canonical" href={fullUrl.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={fullUrl.href} />
    <meta property="og:image" content={new URL(image, siteUrl).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Ruta Express" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, siteUrl).href} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Ruta Express",
        "url": siteUrl.href,
        "description": description,
        "inLanguage": "es-AR",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": `${siteUrl.href}?buscar={search_term_string}`
          },
          "query-input": "required name=search_term_string"
        }
      })}
    </script>

    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Ruta Express",
        "url": siteUrl.href,
        "logo": new URL("/favicon.ico", siteUrl).href,
        "description": description,
        "areaServed": {
          "@type": "GeoCircle",
          "geoMidpoint": {
            "@type": "GeoCoordinates",
            "latitude": -33.2931,
            "longitude": -62.3165
          },
          "geoRadius": "100000"
        }
      })}
    </script>

    <meta name="generator" content={Astro.generator} />

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4201246651894763" crossorigin="anonymous"></script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Ir al contenido principal</a>
    <slot />
    <Analytics />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
