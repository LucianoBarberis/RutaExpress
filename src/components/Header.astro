---
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <svg class="logo-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="14" rx="2" />
        <path d="M3 10h18" />
        <path d="M7 7h.01" />
        <path d="M17 7h.01" />
        <path d="M7 17v3" />
        <path d="M17 17v3" />
      </svg>
      <div class="logo-text-wrap">
        <span class="logo-text">Ruta Express</span>
      </div>
    </a>

    <div class="header-right">
      <nav class="nav">
        <a
          href="/"
          class:list={['nav-link', { active: currentPath === '/' }]}
        >
          <svg class="nav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
          <span class="nav-label">Transportes</span>
        </a>
        <a
          href="/contacto"
          class:list={['nav-link', { active: currentPath === '/contacto' }]}
        >
          <svg class="nav-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
            <polyline points="22,6 12,13 2,6" />
          </svg>
          <span class="nav-label">Contacto</span>
        </a>
      </nav>
      <div class="header-clock" id="header-clock" aria-label="Reloj">--:--</div>
    </div>
  </div>
</header>

<script>
  function actualizarReloj() {
    const reloj = document.getElementById('header-clock');
    if (!reloj) return;
    const ahora = new Date();
    const h = String(ahora.getHours()).padStart(2, '0');
    const m = String(ahora.getMinutes()).padStart(2, '0');
    reloj.textContent = `${h}:${m}`;
  }
  actualizarReloj();
  setInterval(actualizarReloj, 10000);
</script>

<style>
  .header {
    background: var(--color-primary);
    height: var(--header-height);
    display: flex;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 100;
    background: linear-gradient(135deg, #003366 0%, #002a52 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    color: white;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .logo-text-wrap {
    display: flex;
    flex-direction: column;
  }

  .logo-text {
    font-size: var(--font-size-xl);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  .logo-tagline {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    line-height: 1;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .nav {
    display: flex;
    gap: 2px;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.65);
    font-size: var(--font-size-sm);
    font-weight: 500;
    padding: 8px 14px;
    text-decoration: none;
    position: relative;
    transition: color var(--transition);
    border-radius: var(--radius-md);
  }

  .nav-link:hover {
    color: white;
    background: rgba(255, 255, 255, 0.07);
  }

  .nav-link.active {
    color: white;
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 14px;
    right: 14px;
    height: 2.5px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .nav-icon {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .nav-link:hover .nav-icon,
  .nav-link.active .nav-icon {
    opacity: 1;
  }

  .header-clock {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.03em;
    padding: 6px 10px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    background: rgba(0, 0, 0, 0.15);
    min-width: 52px;
    text-align: center;
  }

  @media (max-width: 640px) {
    .logo-icon {
      width: 24px;
      height: 24px;
    }

    .logo-text {
      font-size: var(--font-size-base);
    }

    .logo-tagline {
      display: none;
    }

    .nav-link {
      padding: 6px 10px;
      font-size: 0.75rem;
      gap: 4px;
    }

    .nav-link.active::after {
      left: 10px;
      right: 10px;
    }

    .nav-label {
      display: none;
    }

    .header-clock {
      font-size: 0.75rem;
      padding: 4px 8px;
      min-width: 44px;
    }

    .header-right {
      gap: var(--space-sm);
    }
  }

  @media (max-width: 380px) {
    .header-inner {
      padding: 0 var(--space-md);
    }
  }
</style>
