---
---

<form
  class="contact-form"
  action="https://formspree.io/f/mzdlzqaz"
  method="POST"
>
  <div class="form-header">
    <h2 class="form-title">Enviar mensaje</h2>
    <p class="form-desc">Completá el formulario y te respondemos a la brevedad.</p>
  </div>

  <div class="form-body">
    <div class="form-row">
      <div class="form-group">
        <label for="nombre">Nombre completo *</label>
        <input type="text" id="nombre" name="nombre" required placeholder="Juan Perez" />
      </div>
      <div class="form-group">
        <label for="telefono">Telefono *</label>
        <input type="tel" id="telefono" name="telefono" required placeholder="+54 9 11 5555-5555" />
      </div>
    </div>

    <div class="form-group">
      <label for="email">Email (opcional)</label>
      <input type="email" id="email" name="email" placeholder="juan@email.com" />
    </div>

    <div class="form-group">
      <label for="asunto">Asunto *</label>
      <select id="asunto" name="asunto" required>
        <option value="">Seleccionar...</option>
        <option value="editar">Quiero editar mi informacion</option>
        <option value="borrar">Quiero borrar mi informacion</option>
        <option value="agregar">Quiero agregar mi servicio</option>
        <option value="otro">Otro</option>
      </select>
    </div>

    <div class="form-group">
      <label for="mensaje">Mensaje *</label>
      <textarea id="mensaje" name="mensaje" required rows="4" placeholder="Describi lo que necesitas..."></textarea>
    </div>

    <button type="submit" class="btn-submit">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 2L11 13" />
        <path d="M22 2l-7 20-4-9-9-4 20-7z" />
      </svg>
      Enviar mensaje
    </button>

    <p class="form-note">* Campos obligatorios. Tu informacion se usa solo para responder tu consulta.</p>
  </div>
</form>

<style>
  .contact-form {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .form-header {
    padding: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    background: #f8fafc;
  }

  .form-title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .form-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .form-body {
    padding: var(--space-lg);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .form-group {
    margin-bottom: var(--space-md);
  }

  .form-group label {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 6px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 10px 14px;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-family: inherit;
    color: var(--color-text);
    background: white;
    transition: all var(--transition);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.1);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 100px;
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 12px 24px;
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--font-size-base);
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    justify-content: center;
    transition: all var(--transition);
  }

  .btn-submit:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(249, 115, 22, 0.3);
  }

  .btn-submit:active {
    transform: translateY(0);
  }

  .form-note {
    margin-top: var(--space-md);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
