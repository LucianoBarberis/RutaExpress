---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Filtros from '../components/Filtros.astro';
import AdBanner from '../components/AdBanner.astro';
import data from '../data/transportes.json';

const { empresas, viajes } = data;

const DIAS_SEMANA = ['Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado', 'Domingo'] as const;
const DIA_ABBR: Record<string, string> = {
  Lunes: 'L', Martes: 'M', 'Miércoles': 'X', Jueves: 'J', Viernes: 'V', Sábado: 'S', Domingo: 'D',
};

function formatPhone(tel: string): string {
  return tel.replace(/[^0-9+]/g, '');
}

function whatsappUrl(tel: string): string {
  const clean = tel.replace(/[^0-9]/g, '');
  return `https://wa.me/${clean}`;
}

const empresaMap = new Map(empresas.map((e) => [e.id, e]));

const origenes = [...new Set(viajes.map((t) => t.origen))];

const sortedEmpresas = [...empresas].sort((a, b) => {
  if (a.tipo === b.tipo) return 0;
  return a.tipo === 'comisionista' ? -1 : 1;
});

interface RutaGroup {
  origen: string;
  destino: string;
  viajes: (typeof viajes)[number][];
}

interface Grupo {
  empresa: (typeof empresas)[number];
  rutas: RutaGroup[];
}

const grupos: Grupo[] = sortedEmpresas.map((empresa) => {
  const vjs = viajes.filter((v) => v.empresa_id === empresa.id);
  const rutaMap = new Map<string, (typeof viajes)[number][]>();
  for (const v of vjs) {
    const key = `${v.origen}|${v.destino}`;
    if (!rutaMap.has(key)) rutaMap.set(key, []);
    rutaMap.get(key)!.push(v);
  }
  return {
    empresa,
    rutas: Array.from(rutaMap.entries()).map(([key, viajes]) => {
      const [origen, destino] = key.split('|');
      return { origen, destino, viajes };
    }),
  };
});
---

<Layout
  title="Ruta Express — Transporte para tu pueblo"
  description="Información unificada de colectivos y comisionistas. Horarios, rutas y contactos de transporte de Chañar Ladeado a Rosario. Consultá servicios disponibles."
>
  <Header />

  <main class="main-content">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg-shapes">
          <svg class="hero-illustration" viewBox="0 0 600 400" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Sky glow -->
            <ellipse cx="450" cy="100" rx="250" ry="180" fill="rgba(249,115,22,0.06)" />
            <ellipse cx="200" cy="50" rx="300" ry="120" fill="rgba(59,130,246,0.05)" />
  
            <!-- Far mountains -->
            <path d="M0 280 Q80 180 160 240 Q220 200 280 230 Q340 170 400 220 Q460 190 520 230 Q560 210 600 240 L600 350 L0 350 Z" fill="rgba(255,255,255,0.04)" />
  
            <!-- Near hills -->
            <path d="M0 310 Q100 250 200 280 Q300 240 400 270 Q500 250 600 280 L600 350 L0 350 Z" fill="rgba(255,255,255,0.06)" />
  
            <!-- Road -->
            <path d="M0 370 Q200 340 300 320 Q400 300 600 290" stroke="rgba(255,255,255,0.12)" stroke-width="40" stroke-linecap="round" fill="none" />
            <path d="M0 370 Q200 340 300 320 Q400 300 600 290" stroke="rgba(255,255,255,0.05)" stroke-width="2" stroke-dasharray="8 12" fill="none" />
  
            <!-- Simple bus/trafic -->
            <g transform="translate(280, 295)">
              <rect x="0" y="4" width="44" height="18" rx="4" fill="rgba(249,115,22,0.4)" />
              <rect x="6" y="0" width="20" height="6" rx="2" fill="rgba(249,115,22,0.35)" />
              <circle cx="10" cy="24" r="4" fill="rgba(255,255,255,0.2)" />
              <circle cx="34" cy="24" r="4" fill="rgba(255,255,255,0.2)" />
              <rect x="8" y="6" width="8" height="6" rx="1" fill="rgba(255,255,255,0.15)" />
              <rect x="18" y="6" width="8" height="6" rx="1" fill="rgba(255,255,255,0.15)" />
              <rect x="28" y="6" width="8" height="6" rx="1" fill="rgba(255,255,255,0.15)" />
            </g>
  
            <!-- Trees -->
            <g opacity="0.15">
              <path d="M60 310 L70 270 L80 310 Z" fill="white" />
              <path d="M140 290 L150 255 L160 290 Z" fill="white" />
              <path d="M480 280 L490 245 L500 280 Z" fill="white" />
              <path d="M530 275 L540 240 L550 275 Z" fill="white" />
            </g>
          </svg>
      </div>
      <div class="container">
        <div class="hero-content">
          <div class="hero-text">
            <h1 class="hero-title">Transportes Chañar Ladeado</h1>
            <p class="hero-subtitle">
              Informacion unificada de colectivos y comisionistas. Horarios,
              rutas y contactos, todo en un solo lugar.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="container">
      <AdBanner position="top" />

      <Filtros origenes={origenes} />

      <!-- Tabla / Cards -->
      <div class="table-section">
        <div class="table-header">
          <h2 class="table-title">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="14" rx="2" />
              <path d="M3 10h18" />
              <path d="M7 7h.01" />
              <path d="M17 7h.01" />
            </svg>
            Servicios disponibles
          </h2>
          <span class="table-count">{empresas.length} empresas · {viajes.length} viajes</span>
        </div>

        <div id="grupos-container">
        {grupos.map(({ empresa, rutas }) => {
          const todosDias = [...new Set(rutas.flatMap((r) => r.viajes.flatMap((v) => v.horarios.flatMap((h) => h.dias))))];
          return (
            <details class="grupo-empresa" data-tipo={empresa.tipo} data-origen={rutas.map((r) => r.origen).join(',')} data-dias={todosDias.join(',')}>
              <summary class="grupo-summary">
                <span class:list={['badge', empresa.tipo === 'colectivo' ? 'badge-colectivo' : 'badge-comisionista']}>
                  {empresa.tipo === 'colectivo' ? 'Colectivo' : 'Comisionista'}
                </span>
                <span class="grupo-nombre">{empresa.nombre}</span>
                {empresa.vehiculo && <span class="grupo-vehiculo">{empresa.vehiculo}</span>}
                <span class="grupo-count">{rutas.reduce((n, r) => n + r.viajes.length, 0)} viajes</span>
                <a
                  href={whatsappUrl(empresa.telefono)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-whatsapp"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                    <path d="M12 2C6.477 2 2 6.477 2 12c0 1.88.515 3.642 1.416 5.14L2 22l4.86-1.416A9.967 9.967 0 0 0 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
                  </svg>
                  <span class="btn-label">WhatsApp</span>
                </a>
              </summary>

              <div class="grupo-content">
                <div class="grupo-inner">
                  {rutas.map((ruta) => {
                    const rutaDias = [...new Set(ruta.viajes.flatMap((v) => v.horarios.flatMap((h) => h.dias)))];
                    return (
                      <div class="ruta-group" data-origen={ruta.origen}>
                        <div class="ruta-heading">
                          <svg class="ruta-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10" />
                            <path d="M12 6v6l4 2" />
                          </svg>
                          <span class="ruta-origen">{ruta.origen}</span>
                          <svg class="ruta-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14" />
                            <path d="m14 7 5 5-5 5" />
                          </svg>
                          <span class="ruta-destino">{ruta.destino}</span>
                        </div>

                        <!-- Desktop table -->
                        <div class="table-wrap">
                          <table class="tabla tabla-ruta">
                            <thead>
                              <tr>
                                <th>Salida</th>
                                <th>Llegada</th>
                                <th>Días</th>
                                <th class="note-col"></th>
                              </tr>
                            </thead>
                            <tbody>
                              {ruta.viajes.flatMap((v) => {
                                const allDias = [...new Set(v.horarios.flatMap((h) => h.dias))];
                                return v.horarios.map((h, hi) => (
                                  <tr
                                    class="transporte-row"
                                    data-tipo={empresa.tipo}
                                    data-origen={v.origen}
                                    data-dias={allDias.join(',')}
                                    style={`animation-delay: ${(v.id % 10) * 0.04}s`}
                                  >
                                    <td data-label="Salida" class="cell-time">{h.salida}</td>
                                    <td data-label="Llegada" class="cell-time">{h.llegada}</td>
                                    <td data-label="Días" class="cell-dias">
                                      <div class="day-dots">
                                        {DIAS_SEMANA.map((day) => (
                                          <span
                                            class:list={['day-dot', h.dias.includes(day) && 'active']}
                                            title={day}
                                          >{DIA_ABBR[day]}</span>
                                        ))}
                                      </div>
                                      {v.feriados && <span class="feriados-badge" title="También feriados">+F</span>}
                                    </td>
                                    <td data-label="Nota" class="note-col">
                                      {hi === 0 && v.observaciones && <span class="obs-note">{v.observaciones}</span>}
                                    </td>
                                  </tr>
                                ));
                              })}
                            </tbody>
                          </table>
                        </div>

                        <!-- Mobile cards -->
                        <div class="cards-mobile">
                          {ruta.viajes.flatMap((v) => {
                            const allDias = [...new Set(v.horarios.flatMap((h) => h.dias))];
                            return v.horarios.map((h, hi) => (
                              <article
                                class="card-mobile"
                                data-tipo={empresa.tipo}
                                data-origen={v.origen}
                                data-dias={allDias.join(',')}
                                style={`animation-delay: ${(v.id % 10) * 0.04}s`}
                              >
                                <div class="card-mobile-row card-route-row">
                                  <span class="card-mobile-value route">{v.origen} &rarr; {v.destino}</span>
                                </div>
                                <div class="card-time-row">
                                  <span class="card-time-label">Sale</span>
                                  <span class="card-time-value">{h.salida}</span>
                                  <span class="card-time-sep">&rarr;</span>
                                  <span class="card-time-label">Llega</span>
                                  <span class="card-time-value">{h.llegada}</span>
                                </div>
                                <div class="card-dias-row">
                                  <div class="day-dots">
                                    {DIAS_SEMANA.map((day) => (
                                      <span
                                        class:list={['day-dot', h.dias.includes(day) && 'active']}
                                        title={day}
                                      >{DIA_ABBR[day]}</span>
                                    ))}
                                  </div>
                                  {v.feriados && <span class="feriados-badge" title="También feriados">+F</span>}
                                </div>
                                {hi === 0 && v.observaciones && (
                                  <div class="card-obs">{v.observaciones}</div>
                                )}
                              </article>
                            ));
                          })}
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            </details>
          );
        })}
        </div>

        <p class="sin-resultados hidden" id="sin-resultados">
          No se encontraron servicios con esos filtros.
        </p>

        <p class="table-footer">
          Los horarios pueden variar. Consulte directamente con el transportista
          para confirmar disponibilidad.
        </p>
      </div>

      <AdBanner position="bottom" />
    </div>
  </main>

  <Footer />
</Layout>

<script is:inline>
  function shuffleEmpresas() {
    var container = document.getElementById('grupos-container');
    if (!container) return;

    var grupos = Array.from(container.children);
    var comisionistas = grupos.filter(function(g) { return g.dataset.tipo === 'comisionista'; });
    var colectivos = grupos.filter(function(g) { return g.dataset.tipo === 'colectivo'; });

    function fisherYates(arr) {
      var a = arr.slice();
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var tmp = a[i];
        a[i] = a[j];
        a[j] = tmp;
      }
      return a;
    }

    var orden = fisherYates(comisionistas).concat(fisherYates(colectivos));
    orden.forEach(function(g) { container.appendChild(g); });
  }

  document.addEventListener('astro:page-load', shuffleEmpresas);
  shuffleEmpresas();
</script>

<style>
  /* ===== Hero ===== */
  .hero {
    background: linear-gradient(135deg, #003366 0%, #004080 50%, #002b5c 100%);
    padding: var(--space-4xl) 0 var(--space-2xl);
    position: relative;
    overflow: hidden;
    min-height: 320px;
    display: flex;
    align-items: center;
  }

  .hero-bg-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-illustration {
    position: absolute;
    right: -80px;
    bottom: -20px;
    width: 75%;
    height: auto;
    max-width: 700px;
    opacity: 1;
    
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-text {
    max-width: 520px;
  }

  .hero-title {
    font-size: var(--font-size-display);
    font-weight: 300;
    color: white;
    line-height: 1.1;
    margin-bottom: var(--space-md);
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
  }

  /* ===== Table Section ===== */
  .table-section {
    margin-top: var(--space-2xl);
  }

  .table-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-md);
    padding: 0 var(--space-xs);
  }

  .table-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--color-text);
  }

  .table-title svg {
    color: var(--color-primary);
  }

  .table-count {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-weight: 500;
    background: var(--color-surface);
    padding: 4px 14px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
  }

  /* ===== Grupo Empresa (details/summary) ===== */
  .grupo-empresa {
    margin-bottom: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.3s ease;
  }

  .grupo-empresa[open] {
    box-shadow: var(--shadow-md);
  }

  .grupo-summary {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-lg);
    cursor: pointer;
    list-style: none;
    user-select: none;
    background: #f8fafc;
    border-bottom: 1px solid transparent;
    transition: background-color 0.25s ease;
  }

  .grupo-empresa[open] .grupo-summary {
    border-bottom-color: var(--color-border);
    background: #f1f5f9;
  }

  .grupo-summary::-webkit-details-marker {
    display: none;
  }

  .grupo-summary::before {
    content: '▶';
    font-size: 11px;
    color: var(--color-text-muted);
    transition: transform 0.3s ease;
    margin-right: var(--space-xs);
    flex-shrink: 0;
  }

  .grupo-empresa[open] .grupo-summary::before {
    transform: rotate(90deg);
  }

  .grupo-nombre {
    font-weight: 700;
    font-size: var(--font-size-base);
    color: var(--color-primary);
  }

  .grupo-vehiculo {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-left: var(--space-xs);
  }

  .grupo-count {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-left: var(--space-xs);
  }

  .grupo-summary .btn-whatsapp {
    margin-left: auto;
  }

  /* ===== Smooth details animation ===== */
  .grupo-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
  }

  .grupo-empresa[open] .grupo-content {
    grid-template-rows: 1fr;
  }

  .grupo-inner {
    overflow: hidden;
  }

  /* ===== Ruta Groups ===== */
  .ruta-group {
    border-top: 1px solid var(--color-border);
  }

  .ruta-group:first-child {
    border-top: none;
  }

  .ruta-heading {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    background: #fafbfc;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    border-bottom: 1px solid #e5e7eb;
  }

  .ruta-icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .ruta-arrow {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .ruta-origen, .ruta-destino {
    font-weight: 600;
    color: var(--color-text);
  }

  .ruta-origen {
    color: var(--color-primary);
  }

  .ruta-destino {
    color: var(--color-accent);
  }

  /* ===== Day Dots ===== */
  .day-dots {
    display: inline-flex;
    gap: 3px;
    align-items: center;
  }

  .day-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    color: #b0b8c5;
    background: transparent;
    border: 1.5px solid #e0e4ea;
    transition: all 0.15s ease;
    line-height: 1;
  }

  .day-dot.active {
    color: var(--color-primary);
    background: #e8eef6;
    border-color: var(--color-primary);
  }

  .feriados-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 4px;
    font-size: 9px;
    font-weight: 700;
    color: var(--color-accent);
    background: #fff3e6;
    border: 1.5px solid var(--color-accent);
    margin-left: 4px;
    line-height: 1;
  }

  /* ===== Desktop Table ===== */
  .table-wrap {
    background: var(--color-surface);
    overflow: hidden;
    overflow-x: auto;
  }

  .ruta-group .table-wrap {
    border: none;
    border-radius: 0;
    box-shadow: none;
  }

  .tabla-ruta th {
    background: transparent;
    color: var(--color-text-muted);
    font-weight: 600;
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 10px 16px;
    text-align: left;
    white-space: nowrap;
    border-bottom: 1px solid #e5e7eb;
  }

  .tabla-ruta td {
    padding: 12px 16px;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
    color: var(--color-text);
    font-size: var(--font-size-sm);
  }

  .tabla-ruta tbody tr:last-child td {
    border-bottom: none;
  }

  .tabla-ruta .note-col {
    width: 1%;
    white-space: nowrap;
  }

  .obs-note {
    font-size: var(--font-size-xs);
    color: var(--color-accent);
    font-style: italic;
  }

  .transporte-row {
    transition: background-color 0.15s ease;
    animation: fadeInUp 0.3s ease both;
  }

  .transporte-row.hidden {
    display: none;
  }

  .transporte-row:hover td {
    background: #f8fafc;
  }

  .cell-time {
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    font-size: var(--font-size-base);
    white-space: nowrap;
  }

  .cell-dias {
    vertical-align: middle;
  }

  .badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: var(--font-size-xs);
    font-weight: 600;
    white-space: nowrap;
  }

  .badge-colectivo {
    background: #dbeafe;
    color: #1e40af;
  }

  .badge-comisionista {
    background: #fef3c7;
    color: #92400e;
  }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #25d366;
    color: white;
    padding: 7px 14px;
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition);
    white-space: nowrap;
  }

  .btn-whatsapp:hover {
    background: #1da85a;
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.35);
    color: white;
    transform: translateY(-1px);
